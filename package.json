{
  "name": "js-confuser",
  "version": "2.1.2",
  "description": "JavaScript Obfuscation Tool.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "npm run typecheck && tsdown",
    "dev": "tsx dev.ts",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage --coverageReporters=html",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": [
    "obfuscator",
    "obfuscation",
    "uglify",
    "code protection",
    "javascript obfuscator",
    "js obfuscator"
  ],
  "author": "MichaelXF",
  "license": "MIT",
  "dependencies": {
    "@babel/generator": "^7.28.0",
    "@babel/parser": "^7.28.0",
    "@babel/traverse": "^7.28.0",
    "@babel/types": "^7.28.2",
    "lz-string": "^1.5.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.2.0",
    "cross-env": "^10.1.0",
    "globals": "^15.9.0",
    "jest": "^29.7.0",
    "tsdown": "^0.22.2",
    "tsx": "^4.22.4",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MichaelXF/js-confuser"
  },
  "bugs": {
    "url": "https://github.com/MichaelXF/js-confuser/issues"
  },
  "homepage": "https://js-confuser.com",
  "engines": {
    "node": ">=18.0.0"
  }
}
